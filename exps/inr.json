{
    "prefix": "inr",
    "dataset": "imagenetr",
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "cllora",
    "backbone_type": "vit_base_patch16_224_in21k_cllora",
    "device": ["0"],
    "seed": [1993],
    "init_epochs": 25,
    "init_lr": 0.05,
    "later_epochs": 25,
    "later_lr": 0.05,
    "batch_size": 32,
    "weight_decay": 0.005,
    "ffn_num": 10,
    "specific_lora_init_scale": 0.001,
    "task_specific_adapter": {
        "use_orth_loss": true
    },
    "sd_lora": {
        "r0": 10,
        "r_min": 7,
        "alpha_init": 0.13
    },
    "ewc": {
        "lambda": 130,
        "gamma": 0.9,
        "fisher_sample_size": 1024,
        "fisher_batch_size": 32,
        "fisher_clip": 2.0
    }
}
