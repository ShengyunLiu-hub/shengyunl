{
    "prefix": "cifar",
    "dataset": "cifar224",
    "shuffle": true,
    "init_cls": 5,
    "increment": 5,
    "model_name": "cllora",
    "backbone_type": "vit_base_patch16_224_in21k_cllora",
    "device": ["0"],
    "seed": [1993],
    "init_epochs": 30,
    "init_lr": 0.05,
    "later_epochs": 30,
    "later_lr": 0.05,
    "batch_size": 64,
    "weight_decay": 0.0001,
    "ffn_num": 8,
    "specific_lora_init_scale": 0.005,
    "task_specific_adapter": {
        "use_orth_loss": true
    },
    "sd_lora": {
        "r0": 8,
        "r_min": 4,
        "alpha_init": 0.1,
        "direction_norm_eps": 1e-05
    },
    "ewc": {
        "lambda": 180,
        "fisher_sample_size": 1024,
        "fisher_batch_size": 64
    }
}
